# Supabase Configuration
# Used by both client and server. Must be set in Netlify build environment variables.
NEXT_PUBLIC_SUPABASE_URL=https://[project].supabase.co

# Used by the server-side Supabase client (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Used by the client-side Supabase client for storage uploads
# This is the anon/public key from Supabase. RLS policies must allow anonymous uploads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI Configuration
# Used by the server for prompt enhancement and image generation
OPENAI_API_KEY=